{
  "name": "tecnofit-enxuto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/pre-start.mjs && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:apply": "node scripts/pre-start.mjs",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx src/workers/index.ts",
    "pilot:infra": "docker compose up -d postgres redis",
    "pilot:infra:down": "docker compose down",
    "pilot:worker:docker": "docker compose --profile pilot up -d --build worker",
    "pilot:setup": "node scripts/pilot-setup.mjs",
    "pilot:check": "node scripts/pilot-check.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.76.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.52.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.43.1",
    "ioredis": "^5.6.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "papaparse": "^5.5.3",
    "postgres": "^3.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^18.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.18",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
