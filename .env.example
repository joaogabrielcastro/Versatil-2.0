NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://app:app@localhost:5432/tecnofit
REDIS_URL=redis://localhost:6380
JWT_SECRET=troque-esta-chave-com-pelo-menos-32-chars
NEXTAUTH_SECRET=troque-esta-chave-com-pelo-menos-32-chars

# Opcional: cron (Authorization: Bearer ...) e webhooks de gateway
# CRON_SECRET=troque-cron-min-8-chars
# WEBHOOK_INGEST_SECRET=troque-webhook-min-16-chars

# Opcional: seed local (npm run db:seed)
# SEED_TENANT_SLUG=demo
# SEED_USER_EMAIL=recep@demo.com
# SEED_USER_PASSWORD=demo12345678
# SEED_PLATFORM_EMAIL=admin@plataforma.com
# SEED_PLATFORM_PASSWORD=demo12345678

# Observabilidade (worker): logs JSON, métricas de fila, alertas HTTP
# OBSERVABILITY_SERVICE=versatil-worker
# OBSERVABILITY_LOG_FORMAT=json   # ou text (terminal legível)
# OBSERVABILITY_METRICS_INTERVAL_MS=60000
# OBSERVABILITY_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# OBSERVABILITY_ALERT_WEBHOOK_TOKEN=opcional-bearer
# OBSERVABILITY_ALERT_QUEUE_WAITING_THRESHOLD=500
